# Production environment variables
# Copy to .env.prod and fill in real values
# Usage: docker-compose -f docker-compose.prod.yml --env-file .env.prod up -d

# Database
DB_PASSWORD=change-me-strong-random-password

# Redis
REDIS_PASSWORD=change-me-another-password

# Admin
ADMIN_API_KEY=change-me-min-32-chars-random

# Encryption (generate: openssl rand -hex 32)
ENCRYPTION_KEY=change-me-hex-encoded-32-bytes

# OAuth
ISSUER=https://auth.myapp.com
CORS_ORIGINS=https://myapp.com,https://admin.myapp.com

# Email (optional)
SMTP_HOST=smtp.sendgrid.net
SMTP_USERNAME=apikey
SMTP_PASSWORD=SG.xxxxx
SMTP_FROM=noreply@myapp.com

# SMS (optional)
SMS_PROVIDER=twilio
SMS_ACCOUNT_ID=ACxxxxx
SMS_AUTH_TOKEN=xxxxx
SMS_FROM_NUMBER=+1234567890

# WebAuthn (optional)
WEBAUTHN_RP_ID=myapp.com
WEBAUTHN_RP_NAME=MyApp
WEBAUTHN_RP_ORIGINS=https://myapp.com
